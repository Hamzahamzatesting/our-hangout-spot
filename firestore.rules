rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, displayName, email, photoURL, xp, level, streak, plan, createdAt
    //
    // Collection: courses
    // Fields: userId, name, code, description, color, createdAt
    //
    // Collection: materials
    // Fields: userId, courseId, title, type, content, fileUrl, processed, createdAt
    //
    // Collection: flashcards
    // Fields: userId, courseId, front, back, nextReview, interval, ease, createdAt
    //
    // Collection: tasks
    // Fields: userId, courseId, title, dueDate, completed, priority
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "Zgaoui50@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'plan']) &&
             data.uid is string &&
             data.email is string &&
             data.plan in ['free', 'student', 'pro', 'elite'];
    }

    function isValidCourse(data) {
      return data.keys().hasAll(['userId', 'name']) &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    function isValidMaterial(data) {
      return data.keys().hasAll(['userId', 'courseId', 'title', 'type']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() < 200 &&
             data.type in ['pdf', 'lecture', 'textbook', 'slides'];
    }

    function isValidFlashcard(data) {
      return data.keys().hasAll(['userId', 'front', 'back']) &&
             data.userId == request.auth.uid &&
             data.front is string && data.front.size() < 1000 &&
             data.back is string && data.back.size() < 2000;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['userId', 'title', 'dueDate']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() < 200;
    }

    // ----------------------------------------------------------------
    // Users collection – each signed‑in user can read, create, and update
    // only their own profile document. Admins retain full read access.
    // ----------------------------------------------------------------
    match /users/{uid} {
      // Read own profile or allow admins to read any profile
      allow read: if isOwner(uid) || isAdmin();

      // ---- CREATE ---------------------------------------------------
      // Allow a signed‑in user to create their own profile document.
      // The document ID must match the authenticated UID.
      // We also ensure the basic required fields exist (uid, email, plan).
      allow create: if isAuthenticated()
                    && request.auth.uid == uid
                    && isValidUser(request.resource.data);

      // ---- UPDATE ---------------------------------------------------
      // Users can update their own profile as long as the plan field
      // does not change (plan changes are handled elsewhere).
      allow update: if isOwner(uid)
                    && isValidUser(request.resource.data)
                    && request.resource.data.plan == resource.data.plan;
    }

    // ----------------------------------------------------------------
    // Courses collection
    // ----------------------------------------------------------------
    match /courses/{courseId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidCourse(request.resource.data);
      allow update: if isDocOwner() && isValidCourse(request.resource.data);
      allow delete: if isDocOwner();
    }

    // ----------------------------------------------------------------
    // Materials collection
    // ----------------------------------------------------------------
    match /materials/{materialId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidMaterial(request.resource.data);
      allow update: if isDocOwner() && isValidMaterial(request.resource.data);
      allow delete: if isDocOwner();
    }

    // ----------------------------------------------------------------
    // Flashcards collection
    // ----------------------------------------------------------------
    match /flashcards/{cardId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidFlashcard(request.resource.data);
      allow update: if isDocOwner() && isValidFlashcard(request.resource.data);
      allow delete: if isDocOwner();
    }

    // ----------------------------------------------------------------
    // Tasks collection
    // ----------------------------------------------------------------
    match /tasks/{taskId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidTask(request.resource.data);
      allow update: if isDocOwner() && isValidTask(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}

service cloud.firestore {
  match /databases/{database}/documents {

    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isOwn(uid) { return request.auth.uid == uid; }
    function isHost(sessionData) { return request.auth.uid == sessionData.hostId; }
    function isMemberOf(sessionData) {
      return request.auth.uid in sessionData.members || isHost(sessionData);
    }

    // ── User Profiles ──────────────────────────────────────────────────────────
    match /users/{userId} {
      allow get:    if isSignedIn();
      allow list:   if false;
      allow create: if isSignedIn() && isOwn(userId);
      allow update: if isSignedIn() && isOwn(userId);
      allow delete: if false;
    }

    // ── Sessions ───────────────────────────────────────────────────────────────
    match /sessions/{sessionId} {

      // Anyone signed-in who knows the ID can read (enables join-by-link)
      allow get: if isSignedIn();

      // Only members can list their sessions
      allow list: if isSignedIn() && resource.data.members.hasAny([request.auth.uid]);

      // Any signed-in user can create their own session
      allow create: if isSignedIn() && request.resource.data.hostId == request.auth.uid;

      // Members & host can update; non-members can add themselves (join via link)
      allow update: if isSignedIn() && (
        isMemberOf(resource.data) ||
        // Joining: user adds only themselves to members
        (
          !(request.auth.uid in resource.data.members) &&
          request.resource.data.members.hasAll(resource.data.members) &&
          request.resource.data.members.hasAny([request.auth.uid])
        )
      );

      allow delete: if false;

      // ── Plan Options ─────────────────────────────────────────────────────────
      match /options/{optionId} {
        allow read:   if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isSignedIn() && (
          request.auth.uid == resource.data.createdBy ||
          request.auth.uid == get(/databases/$(database)/documents/sessions/$(sessionId)).data.hostId
        );
      }

      // ── Chat Messages ────────────────────────────────────────────────────────
      match /messages/{messageId} {
        allow read:          if isSignedIn();
        allow create:        if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if false;
      }

      // ── Legacy Vibes (Echo Oracle) ───────────────────────────────────────────
      match /vibes/{vibeId} {
        allow read:   if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if false;
      }
    }
  }
}
